Options -Indexes

DirectoryIndex index.html index.php

ErrorDocument 403 /403.html
ErrorDocument 404 /404.html
ErrorDocument 500 /500.html

RewriteEngine On

# Canonical domain: keep old mederak.pl hosts redirect-only.
RewriteCond %{HTTP_HOST} ^(www\.)?mederak\.pl$ [NC]
RewriteRule ^(.*)$ https://mederak.app/$1 [R=301,L,NE]

# Redirect /index.html to /
RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

# Product rename: keep old Excel Backlog Importer URLs working.
RewriteRule ^apps/excel-backlog-importer-for-jira/?$ /apps/excel-to-jira-importer-uploader/ [R=301,L]
RewriteRule ^apps/excel-backlog-importer-for-jira/(.*)$ /apps/excel-to-jira-importer-uploader/$1 [R=301,L]

<IfModule mod_headers.c>
  <FilesMatch "\.(html?)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>
